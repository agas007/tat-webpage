// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// For local testing & development, we use SQLite.
// You can easily switch this provider to "postgresql" or "supabase" by modifying the provider and DATABASE_URL.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  role          String    @default("Client") // "Admin", "Partner", "TeamLeader", "TeamStaff", "Publisher", "Client"
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tasksAssigned Task[]    @relation("TaskAssignee")
  projectsOwned Project[] @relation("ProjectClient")
}

model Project {
  id          String   @id @default(cuid())
  clientId    String
  client      User     @relation("ProjectClient", fields: [clientId], references: [id])
  name        String
  status      String   @default("In Progress") // In Progress, Review, Done
  progress    Int      @default(0)
  lastUpdate  DateTime @default(now())
  nextAction  String?
  
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          String   @id @default(cuid())
  title       String
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  assigneeId  String?
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  status      String   @default("todo") 
  priority    String   @default("Medium") // Low, Medium, High
  dueDate     DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
